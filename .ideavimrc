" --- Generic settings ---
" NOTE: Vim-only options (ruler, lazyredraw, showmatch, copyindent, shiftround,
" visualbell/errorbells) are handled by the IDE itself and are no-ops in IdeaVim,
" so they were removed to keep this file focused on what actually has an effect.
set autoindent
set hlsearch
set incsearch
set scrolloff=5                    " keep some context above/below the cursor
set cursorline
set clipboard=unnamed,unnamedplus " Use system clipboard for yank/paste

" Use case-insensitive search, but switch to case-sensitive if an uppercase letter is used
set ignorecase
set smartcase

" --- IdeaVim integration (IDE-specific) ---
set ideajoin                      " J uses the IDE's smart-join (merges literals, if-stmts, etc.)
set idearefactormode=keep         " stay in normal mode during inline refactorings
set ideamarks                     " sync Vim marks with IDE bookmarks
" Let the IDE own the system copy/paste chords regardless of Vim mode
sethandler <C-c> a:ide
sethandler <C-v> a:ide

" --- Bundled Vim plugins ---
set which-key                     " popup cheatsheet for leader mappings
set timeoutlen=500                " comfortable wait window for which-key / prefixes
set surround                      " cs\"' , ds( , ysiw) around text objects
set highlightedyank               " briefly highlight the yanked region
set commentary                    " gcc / gc{motion} / gcap commenting
set ReplaceWithRegister           " grr / gr{motion} — paste register over target
set argtextobj                    " aa / ia — function argument text object
set textobj-entire                " ae / ie — whole buffer as a text object
set matchit                       " % jumps between matching keywords/tags
let g:highlightedyank_highlight_duration = "200"

" --- Leader Key ---
" Sets the leader key to comma.
let mapleader=","

" --- which-key labels ---
" Format: let g:WhichKeyDesc_<uniqueName> = "<lhs> <label>"
" A '+' prefix marks a group (a prefix that expands into more mappings).

" Groups
let g:WhichKeyDesc_run  = "<leader>r +run"
let g:WhichKeyDesc_find  = "<leader>f +find/file"
let g:WhichKeyDesc_goto  = "<leader>g +goto/git"
let g:WhichKeyDesc_code  = "<leader>c +code"
let g:WhichKeyDesc_hist  = "<leader>h +history"
let g:WhichKeyDesc_win  = "<leader>w +window"

" Run / Debug
let g:WhichKeyDesc_run_debug = "<leader>rd Debug"
let g:WhichKeyDesc_run_run  = "<leader>rr Run"
let g:WhichKeyDesc_stop  = "<leader>ss Stop"

" Find / File
let g:WhichKeyDesc_find_inpath = "<leader>ff Find in files"
let g:WhichKeyDesc_find_usages = "<leader>fu Find usages"
let g:WhichKeyDesc_find_all  = "<leader>fa Search everywhere"
let g:WhichKeyDesc_find_struct = "<leader>fs File structure"
let g:WhichKeyDesc_find_save  = "<leader>fw Save all"

" Goto / Git
let g:WhichKeyDesc_goto_decl = "<leader>gd Go to declaration"
let g:WhichKeyDesc_goto_blame = "<leader>ga Git annotate (blame)"
let g:WhichKeyDesc_goto_pull = "<leader>gp Git pull"

" Code
let g:WhichKeyDesc_code_format  = "<leader>cf Reformat code"
let g:WhichKeyDesc_code_refactor = "<leader>cr Refactor this"

" History
let g:WhichKeyDesc_hist_files = "<leader>hh Recent files"
let g:WhichKeyDesc_hist_changes = "<leader>hc Recent changes"

" Window
let g:WhichKeyDesc_win_vsplit = "<leader>wv Split vertically"
let g:WhichKeyDesc_win_hsplit = "<leader>ws Split horizontally"

" Standalone
let g:WhichKeyDesc_terminal  = "<leader>t Terminal"
let g:WhichKeyDesc_nexttab  = "<leader>n Next tab"
let g:WhichKeyDesc_prevtab  = "<leader>p Prev tab"
let g:WhichKeyDesc_close  = "<leader>d Close editor"
let g:WhichKeyDesc_switcher  = "<leader>b Switcher"
let g:WhichKeyDesc_comment  = "<leader>/ Toggle comment"
let g:WhichKeyDesc_selectall = "<leader>a Select all"
let g:WhichKeyDesc_openbelow = "<leader>o Blank line below"
let g:WhichKeyDesc_openabove = "<leader>O Blank line above"
let g:WhichKeyDesc_nohl  = "<leader><space> Clear search highlight"
let g:WhichKeyDesc_movedown  = "<leader>j Move line down"
let g:WhichKeyDesc_moveup  = "<leader>k Move line up"
" Note: ,r in visual mode is 'replace selection in file'; which-key keys labels
" by the key sequence (not by mode), so it shares the ',r' group label above.

" --- Best Practice: Use non-recursive mappings ---
" For standard Vim commands, `noremap` variants (`nnoremap`, `vnoremap`) are best practice.
" For IDE-specific `<Action>` commands recursion is not a concern, so `map` is used for
" brevity/multi-mode convenience while `nnoremap`/`vnoremap` are used for the rest.

" --- IDE Integration & Code Navigation ---
" Debug current file/project (normal-mode only, so it doesn't clash with visual ,r)
nmap <leader>rd <Action>(Debug)
" Run current file/project
nmap <leader>rr <Action>(Run)
" Stop current run/debug session
nmap <leader>ss <Action>(Stop)
" Find in Files (whole project)
map <leader>ff <Action>(FindInPath)
" Find Usages of the symbol under the cursor
map <leader>fu <Action>(FindUsages)
map <leader>fa <Action>(SearchEverywhere)
" Open File Structure (outline)
map <leader>fs <Action>(FileStructurePopup)
" Go to Declaration
map <leader>gd <Action>(GotoDeclaration)
" Toggle IDE Terminal
map <leader>t <Action>(ActivateTerminalToolWindow)
" Format current file
map <leader>cf <Action>(ReformatCode)
" Quick Refactorings menu
map <leader>cr <Action>(Refactorings.QuickListPopupAction)

" --- File & Buffer Management ---
" Recently opened files
map <leader>hh <Action>(RecentFiles)
" Recent changes
map <leader>hc <Action>(RecentChanges)
" Next editor tab
map <leader>n <Action>(NextTab)
" Previous editor tab
map <leader>p <Action>(PreviousTab)
" Close current editor tab
map <leader>d <Action>(CloseEditor)
" Use the IDE's powerful switcher for buffers, files, and symbols instead of `:b`
map <leader>b <Action>(Switcher)

" Jump to specific tabs (1-9), and last tab ($)
nnoremap <leader>1 1gt
nnoremap <leader>2 2gt
nnoremap <leader>3 3gt
nnoremap <leader>4 4gt
nnoremap <leader>5 5gt
nnoremap <leader>6 6gt
nnoremap <leader>7 7gt
nnoremap <leader>8 8gt
nnoremap <leader>9 9gt

" --- Window Management ---
map <leader>wv <Action>(SplitVertically)
map <leader>ws <Action>(SplitHorizontally)

" --- Editing ---
" Save all files. Bound under the ,f group to avoid the ,w / ,wv / ,ws prefix clash.
map <leader>fw <Action>(SaveAll)

" Commenting code using the IDE's action
map <leader>/ <Action>(CommentByLineComment)
vmap <leader>/ <Action>(CommentByLineComment)

" Select all
map <leader>a <Action>($SelectAll)

" Insert empty line below/above while staying in normal mode on the same line
nnoremap <leader>o o<Esc>k
nnoremap <leader>O O<Esc>j

" Clear search highlights
nnoremap <silent> <leader><space> :noh<CR>

" Move current line / selection up and down using the IDE-native action
" (handles code folds and language syntax better than :m, and keeps the selection)
map <leader>j <Action>(MoveLineDown)
map <leader>k <Action>(MoveLineUp)

" --- Visual Mode ---
" Search for the visually selected text forwards/backwards
vnoremap <silent> * y/<C-R>"<CR>
vnoremap <silent> # y?<C-R>"<CR>

" Replace visually selected text across the whole file.
" Yanks the selection and prepares a substitution command, waiting for your input.
vnoremap <silent> <leader>r y:%s/<C-R>""/g<Left><Left>

" Paste without losing yanked text in visual mode (uses black hole register)
vnoremap <leader>p "_dP

" --- Version Control ---
" Git Annotate (Blame)
map <leader>ga <Action>(Annotate)
" Git Pull
map <leader>gp <Action>(Git.Pull)
